<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <title>Hair Results Platform</title>
    <meta name='viewport' content='width=device-width, initial-scale=1' />

    <style>
      :root {
        --primary: #2563eb;
        --bg: #f9fafb;
        --surface: #ffffff;
        --border: #e5e7eb;
        --text: #111827;
        --muted: #6b7280;
        --radius: 12px;
      }

      * {
        box-sizing: border-box;
        font-family: Inter, system-ui, sans-serif;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
      }

      header {
        background: white;
        border-bottom: 1px solid var(--border);
        padding: 16px 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .container {
        max-width: 1200px;
        margin: auto;
        padding: 32px;
      }

      h1 {
        font-size: 36px;
        margin-bottom: 16px;
      }
      h2 {
        margin: 32px 0 16px;
      }

      /* search */
      .search-box {
        display: flex;
        gap: 8px;
        margin-bottom: 32px;
      }

      .search-box input,
      select {
        padding: 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        flex: 1;
      }

      .btn {
        background: var(--primary);
        color: white;
        border: none;
        padding: 12px 20px;
        border-radius: 8px;
        cursor: pointer;
      }

      /* cards */
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 24px;
      }

      .card {
        background: white;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.03);
      }

      .img {
        height: 180px;
        background: #ddd;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #888;
        font-weight: bold;
      }

      .card-body {
        padding: 16px;
      }

      .badge {
        display: inline-block;
        background: #dcfce7;
        color: #166534;
        font-size: 12px;
        padding: 4px 8px;
        border-radius: 999px;
        margin-left: 6px;
      }

      .muted {
        color: var(--muted);
        font-size: 14px;
      }

      /* sections */
      section {
        margin-bottom: 64px;
      }

      /* layout */
      .split {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 32px;
      }

      .sidebar {
        background: white;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px;
      }

      footer {
        border-top: 1px solid var(--border);
        padding: 24px;
        text-align: center;
        background: white;
      }

      /* HEADER */

      .site-header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: white;
        border-bottom: 1px solid var(--border);
      }

      .header-inner {
        max-width: 1200px;
        margin: auto;
        padding: 12px 32px;
        display: grid;
        grid-template-columns: auto 1fr 2fr auto;
        align-items: center;
        gap: 24px;
      }

      .logo {
        font-size: 22px;
        font-weight: 700;
        text-decoration: none;
        color: var(--text);
      }

      .logo span {
        color: var(--primary);
      }

      .nav {
        display: flex;
        gap: 20px;
      }

      .nav a {
        text-decoration: none;
        color: var(--text);
        font-size: 15px;
      }

      .nav a:hover {
        color: var(--primary);
      }

      .header-search input {
        width: 100%;
        padding: 10px 14px;
        border-radius: 999px;
        border: 1px solid var(--border);
        font-size: 14px;
      }

      .actions {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .actions .login {
        color: var(--muted);
        text-decoration: none;
        font-size: 14px;
      }

      /* Mobile */
      @media (max-width: 900px) {
        .header-inner {
          grid-template-columns: 1fr auto;
        }

        .nav,
        .header-search {
          display: none;
        }
      }

      .user-menu {
        position: relative;
      }

      .avatar-btn {
        border: none;
        background: none;
        cursor: pointer;
        padding: 0;
      }

      .avatar-img {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid var(--border);
      }

      /* Dropdown */
      .user-dropdown {
        position: absolute;
        right: 0;
        top: 48px;
        background: white;
        border: 1px solid var(--border);
        border-radius: 12px;
        min-width: 180px;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08);
        display: none;
        overflow: hidden;
      }

      .user-dropdown a {
        display: block;
        padding: 12px 16px;
        text-decoration: none;
        color: var(--text);
        font-size: 14px;
      }

      .user-dropdown a:hover {
        background: var(--bg);
      }

      .user-dropdown hr {
        border: none;
        border-top: 1px solid var(--border);
        margin: 4px 0;
      }

      .user-dropdown .logout {
        color: #dc2626;
      }

      /* Show dropdown on click */
      .user-menu:focus-within .user-dropdown {
        display: block;
      }

      /* HEADER -- END */
    </style>
  </head>

  <body>

    <!-- HEADER -->
    <header class='site-header'>
      <div class='header-inner'>

        <!-- Logo -->
        <a href='/' class='logo'>
          Hair<span>Results</span>
        </a>

        <!-- Primary Navigation -->
        <nav class='nav'>
          <a href='/results'>Results</a>
          <a href='/hospitals'>Hospitals</a>
          <a href='/blog'>Blog</a>
          <a href='/about'>About</a>
        </nav>

        <!-- Search -->
        <form class='header-search'>
          <input
            type='search'
            placeholder='Search hospitals or results...'
            aria-label='Search'
          />
        </form>

        <!-- Actions -->
        <div class='actions'>
          <!-- USER AVATAR -->
          <div class='user-menu'>

            <button class='avatar-btn' aria-haspopup='true'>
              <img
                src='https://ui-avatars.com/api/?name=Can+Avci'
                alt='User avatar'
                class='avatar-img'
              />
            </button>

            <!-- DROPDOWN -->
            <div class='user-dropdown'>
              <a href='/profile'>My Profile</a>
              <a href='/saved'>Saved Results</a>
              <a href='/submissions'>My Submissions</a>
              <hr />
              <a href='/logout' class='logout'>Logout</a>
            </div>

          </div>
          <a href='/login' class='login'>Login</a>
          <a href='/submit' class='btn'>Submit Result</a>
        </div>

      </div>
    </header>

    <!-- HOMEPAGE -->
    <div class='container'>
      <section>
        <h1>Find Real Hair Transplant Results</h1>

        <div class='search-box'>
          <input placeholder='Search by hospital, city, technique...' />
          <select><option>FUE</option><option>DHI</option></select>
          <select><option>6 Months</option></select>
          <button class='btn'>Search</button>
        </div>

        <h2>Latest Results</h2>
        <div class='grid'>
          <div class='card'>
            <img
              src='https://elithair.co.uk/wp-content/uploads/2021/08/before-after-hair-transplant-fue-sapphire-3700-grafts-frederik-g.jpg'
              class='img'
              alt=''
            />
            <div class='card-body'>
              <strong>MediClinic</strong>
              <span class='badge'>Verified</span>
              <div class='muted'>6 Months · 3200 grafts</div>
            </div>
          </div>

          <div class='card'>
            <img
              src='https://elithair.co.uk/wp-content/uploads/2021/08/before-after-hair-transplant-fue-sapphire-3700-grafts-frederik-g.jpg'
              class='img'
              alt=''
            />
            <div class='card-body'>
              <strong>Folica Hair Center</strong>
              <span class='badge'>Verified</span>
              <div class='muted'>12 Months · 4000 grafts</div>
            </div>
          </div>
        </div>
      </section>

      <!-- RESULTS GALLERY -->
      <section>
        <h2>Results Gallery</h2>
        <div class='split'>
          <div class='sidebar'>
            <strong>Filters</strong>
            <p class='muted'>Technique</p>
            <p class='muted'>Months</p>
            <p class='muted'>Hospital</p>
          </div>

          <div class='grid'>
            <div class='card'>
              <div class='img'>Before / After</div>
              <div class='card-body'>
                <strong>HairPlus Center</strong>
                <div class='muted'>4 Months · 2800 grafts</div>
              </div>
            </div>

            <div class='card'>
              <div class='img'>Before / After</div>
              <div class='card-body'>
                <strong>Elite Hair Clinic</strong>
                <div class='muted'>6 Months · 3500 grafts</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- RESULT DETAIL PAGE -->
      <section>
        <h2>Result Detail</h2>

        <div class='card'>
          <div class='img' style='height:300px'>Before / After / 6m / 12m</div>
          <div class='card-body'>
            <strong>MediClinic</strong>
            <div class='muted'>FUE · 3900 grafts · Dr. John Carter</div>

            <h3>Growth Timeline</h3>
            <p class='muted'>0 → 3 → 6 → 12 Months</p>
          </div>
        </div>
      </section>

      <!-- HOSPITAL PROFILE -->
      <section>
        <h2>Hospital Profile</h2>

        <div class='card'>
          <div class='img' style='height:240px'>Hospital Photos</div>
          <div class='card-body'>
            <strong>Folica Hair Center</strong>
            <div class='muted'>Istanbul, Turkey · ⭐ 4.8 (120 reviews)</div>

            <h3>Patient Results</h3>
            <div class='grid'>
              <div class='card'><div class='img'>Before / After</div></div>
              <div class='card'><div class='img'>Before / After</div></div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <footer>
      © 2026 HairResults · Results may vary · Medical disclaimer
    </footer>

  </body>
</html>