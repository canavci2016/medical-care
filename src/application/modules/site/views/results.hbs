<!-- PAGE HEADER -->
<section class='page-header'>
  <div class='container'>
    <h1>Patient Results Gallery</h1>
    <p>Real before and after photos from verified patients. See the
      transformations achieved by our partner hospitals.</p>
    <div class='breadcrumb'>
      <a href='index.html'>Home</a>
      <span class='sep'>›</span>
      <span>Results</span>
    </div>
  </div>
</section>

<!-- FILTER + RESULTS -->
<section class='section'>
  <div class='container'>

   <form class='filter-bar' method='GET' action='/results'>
      <div class='search-input'>
        <svg
          width='16'
          height='16'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
        ><circle cx='11' cy='11' r='8' /><path d='m21 21-4.35-4.35' /></svg>
        <input
          type='text'
          name='name'
          value="{{filters.name}}"
          placeholder='Search hospitals by name or location...'
        />
      </div>
      <select name='procedure'>
        <option value=''>All Procedures</option>
      {{#each filters.procedures}}
        <option {{#if selected}}selected{{/if}} value='{{value}}'>{{label}}</option>
      {{/each}}
      </select>
      <select name='technique'>
        <option value=''>All Techniques</option>
      {{#each filters.techniques}}
        <option {{#if selected}}selected{{/if}} value='{{value}}'>{{label}}</option>
      {{/each}}
      </select>
      <select name='graftCount'>
        <option value=''>All Graft Counts</option>
     {{#each filters.graftCounts}}
        <option {{#if selected}}selected{{/if}} value='{{value}}'>{{label}}</option>
      {{/each}}
      </select>
      <select name='ageRange'>
        <option value=''>All Age ranges</option>
         {{#each filters.ageRanges}}
        <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>
      <button type='submit' class='btn btn-primary btn-sm'>Search</button>
    </form>

    <div class='grid-3' id='resultsGrid'>

      {{#each results}}
  
     <a href="/results/{{this.id}}" class="card filterable-card fade-in" data-technique="{{this.technique}}" data-grafts="{{this.graftCount}}" data-hospital="{{this.hospital.name}}">
          <div class="card-image">
            <img src="{{this.imageUrl}}" alt="{{this.technique}} Hair Transplant Result">
            <div class="overlay">
              <span class="badge badge-blue">{{this.technique}}</span>
              <span class="badge badge-green">{{this.graftCount}} Grafts</span>
            </div>
          </div>
          <div class="card-body">
            <h3>{{this.technique}} Hair Transplant — {{this.graftCount}} Grafts</h3>
            <div class="ba-meta">
              <span>👨‍⚕️ Dr. Mehmet Yilmaz</span>
              <span>🏥 {{this.hospital.name}}</span>
              <span>📅 {{relative_date this.operationDate}}</span>
            </div>
            <span class="view-detail-link">View Full Case →</span>
          </div>
        </a>
      {{/each}}

    </div>

    <!-- Pagination -->
    <div
      class='pagination'
      data-pagination='resultsGrid'
      data-total-pages='{{pagination.totalPages}}'
    ></div>
  </div>
</section>

<!-- CTA -->
<section class='cta-section'>
  <div class='container'>
    <h2>Want Results Like These?</h2>
    <p>Book a free consultation with one of our expert surgeons and start your
      transformation journey today.</p>
    <div class='cta-actions'>
      <a href='contact.html' class='btn btn-primary'>Get Free Consultation</a>
      <a
        href='doctors.html'
        class='btn btn-outline'
        style='border-color: #fff; color: #fff;'
      >Browse Doctors</a>
    </div>
  </div>
</section>