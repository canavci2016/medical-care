    <div class='container'>

      <h1>Hair Transplant Results</h1>
      <p class='muted'>Browse verified patient results from trusted hospitals.</p>

      <div class='layout'>

        <aside>
          <h3>Filters</h3>

          <form action="">


          <label>Procedure
            <select name="procedure">
              <option value=''>All</option>
              {{#each filters.procedures}}
                <option {{#if selected}}selected{{/if}} value='{{value}}'>{{label}}</option>
              {{/each}}
            </select>
          </label>

          <label>Technique
            <select name="technique">
              <option value=''>All</option>
              {{#each filters.techniques}}
                <option {{#if selected}}selected{{/if}} value='{{value}}'>{{label}}</option>
              {{/each}}
            </select>
          </label>

          <label>Age Range
            <select name="ageRange">
              <option value=''>Any</option>
              {{#each filters.ageRanges}}
                <option {{#if selected}}selected{{/if}} value='{{value}}'>{{label}}</option>
              {{/each}}
            </select>
          </label>

          <label>Graft Count
            <select name="graftCount">
              <option value="">Any</option>
            {{#each filters.graftCounts}}
                <option {{#if selected}}selected{{/if}} value='{{value}}'>{{label}}</option>
              {{/each}}
            </select>
          </label>

          <label>Duration
            <select name="duration">
              <option value="">Any</option>
            {{#each filters.availableMonths}}
                <option {{#if selected}}selected{{/if}} value='{{value}}'>{{label}}</option>
              {{/each}}
            </select>
          </label>

          <label>
            <input  {{#if filters.verified.selected}}checked{{/if}} name="verified" type='checkbox' />
            Verified only
          </label>

          <button>Apply Filters</button>
          </form>
        </aside>

        <section>
          <div class='toolbar'>
            <span class='muted'>Showing {{pagination.length}} of {{pagination.total}} results</span>
            <select><option>Sort: Featured</option></select>
          </div>

          <div class='grid'>

            {{#each results}}

              <div class='card' onclick="window.location='/results/{{id}}'">
                <img width="400" height="300" src='{{#if image}}{{image}}{{else}}https://via.placeholder.com/400x400?text=No+Image{{/if}}' alt='{{hospital.name}} hair transplant result image' />
                <div class='card-body'>
                  <strong>{{hospital.name}}</strong>
                  {{#if verified}}
                  <span class='badge'>Verified</span>
                  {{/if}}
                  <div class='muted'>{{technique}} · {{graftCount}} grafts · {{operationDateRelative}}</div>
                  <div class='actions'>
                    <button>♡ Save</button>
                    <button>⇄ Compare</button>
                  </div>
                </div>
              </div>
            {{/each}}

          </div>

            {{> pagination pagination=pagination }}


        </section>

      </div>
    </div>