<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <title>{{#if seo.title}}{{seo.title}}{{else}}Hair Results Platform{{/if}}</title>
    <meta
      name='google-site-verification'
      content='XoHpajvB7DSFCP5DmC0JGiNHsbvOgI5CU8eZuUwu14w'
    />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    {{#if seo.keywords}}
      <meta name='keywords' content='{{seo.keywords}}' />
    {{/if}}
    {{#if seo.description}}
      <meta name='description' content='{{seo.description}}' />
    {{/if}}
    {{#if seo.canonical}}
      <link rel='canonical' href='{{seo.canonical}}' />
    {{/if}}
    {{#if seo.ogType}}
      <meta property='og:type' content='{{seo.ogType}}' />
    {{/if}}
    {{#if seo.ogTitle}}
      <meta property='og:title' content='{{seo.ogTitle}}' />
    {{/if}}
    {{#if seo.ogDescription}}
      <meta property='og:description' content='{{seo.ogDescription}}' />
    {{/if}}
    {{#if seo.ogUrl}}
      <meta property='og:url' content='{{seo.ogUrl}}' />
    {{/if}}
    {{#if seo.ogImage}}
      <meta property='og:image' content='{{seo.ogImage}}' />
    {{/if}}
    <meta property='og:site_name' content='Medical Care' />
    <meta name='twitter:card' content='summary_large_image' />
    {{#if seo.twitterTitle}}
      <meta name='twitter:title' content='{{seo.twitterTitle}}' />
    {{/if}}
    {{#if seo.twitterDescription}}
      <meta name='twitter:description' content='{{seo.twitterDescription}}' />
    {{/if}}
    {{#if seo.twitterImage}}
      <meta name='twitter:image' content='{{seo.twitterImage}}' />
    {{/if}}

    <style>
      :root {
        --primary: #2563eb;
        --bg: #f9fafb;
        --surface: #ffffff;
        --border: #e5e7eb;
        --text: #111827;
        --muted: #6b7280;
        --radius: 12px;
      }

      * {
        box-sizing: border-box;
        font-family: Inter, system-ui, sans-serif;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
      }

      header {
        background: white;
        border-bottom: 1px solid var(--border);
        padding: 16px 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .container {
        max-width: 1200px;
        margin: auto;
        padding: 32px;
      }

      h1 {
        font-size: 36px;
        margin-bottom: 16px;
      }
      h2 {
        margin: 32px 0 16px;
      }

      /* sections */
      section {
        margin-bottom: 64px;
      }

      /* layout */
      .split {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 32px;
      }

      .sidebar {
        background: white;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px;
      }

      /* FOOTER */
      footer {
        margin-top: 80px;
        padding: 30px;
        background-color: #0d6efd;
        color: white;
        text-align: center;
        font-size: 14px;
      }

      /* HEADER */

      .header {
        background: #0d6efd;
        color: white;
        padding: 40px 40px;
        position: sticky;
        top: 0;
        z-index: 1000;
      }

      .nav-container {
        max-width: 1100px;
        margin: auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .logo {
        font-weight: bold;
        font-size: 20px;
        margin-right: 5%;
      }

      /* NAV LINKS */
      .nav-links {
        display: flex;
        gap: 20px;
      }

      .nav-links a {
        color: white;
        text-decoration: none;
        font-size: 16px;
      }

      .nav-links a:hover {
        text-decoration: underline;
      }

      /* MOBILE */
      .menu-toggle {
        display: none;
        font-size: 24px;
        cursor: pointer;
      }

      /* RESPONSIVE */
      @media (max-width: 768px) {
        .nav-links {
          position: absolute;
          top: 60px;
          left: 0;
          width: 100%;
          background: #0d6efd;
          flex-direction: column;
          display: none;
          padding: 15px 0;
        }

        .nav-links a {
          padding: 10px 20px;
          display: block;
        }

        .nav-links.active {
          display: flex;
        }

        .menu-toggle {
          display: block;
        }
      }

      /* HEADER END */
    </style>

    {{#each styles}}
      <link rel='stylesheet' href='/css/{{this}}' />
    {{/each}}

  </head>

  <body>

    <header class='header'>
      <div class='nav-container'>

        <!-- LOGO -->
        <div class='logo'>
          HairResult
        </div>

        <!-- DESKTOP NAV -->
        <nav class='nav-links' id='navLinks'>
          <a href='/'>Home</a>
          <a href='/hospitals'>Hospitals</a>
          <a href='/results'>Results</a>
          <a href='/blogs'>Blog</a>
          <a href='/about'>About</a>
        </nav>

        <!-- MOBILE TOGGLE -->
        <div class='menu-toggle' onclick='toggleMenu()'>
          ☰
        </div>

      </div>
    </header>

    <!-- HOMEPAGE -->
    {{{body}}}

    <footer>
      © 2026 HairResults · Results may vary · Medical disclaimer
    </footer>

    <script>
      function toggleMenu() {
      document.getElementById("navLinks").classList.toggle("active"); }
    </script>

    {{#each scripts}}
      <script src='/js/{{this}}'></script>
    {{/each}}
  </body>
</html>