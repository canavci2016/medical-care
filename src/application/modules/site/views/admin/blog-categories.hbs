<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin | Blog Categories</title>
    <link rel="stylesheet" href="/css/admin/adminlte.css" />
  </head>
  <body class="bg-body-tertiary">
    <main class="app-main p-3 p-md-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Blog Categories</h3>
        <a href="/admin/blog-categories/create" class="btn btn-primary btn-sm">Create Category</a>
      </div>

      <div class="card card-primary card-outline">
        <div class="card-header"><div class="card-title">Category List</div></div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table mb-0">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Slug</th>
                  <th style="width: 120px">Action</th>
                </tr>
              </thead>
              <tbody>
                {{#if categories.length}}
                  {{#each categories}}
                    <tr>
                      <td>{{this.name}}</td>
                      <td>{{this.slug}}</td>
                      <td>
                        <a href="/admin/blog-categories/{{this.id}}/detail" class="btn btn-sm btn-outline-primary">Detail</a>
                      </td>
                    </tr>
                  {{/each}}
                {{else}}
                  <tr>
                    <td colspan="3" class="text-center py-4">No categories found.</td>
                  </tr>
                {{/if}}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
