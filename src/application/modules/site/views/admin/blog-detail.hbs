      <main class="app-main">
        <div class="app-content-header">
          <div class="container-fluid">
            <div class="row align-items-center">
              <div class="col-sm-6"><h3 class="mb-0">Blog Detail</h3></div>
              <div class="col-sm-6 text-sm-end mt-2 mt-sm-0">
                <a href="/admin/blogs" class="btn btn-outline-secondary btn-sm">Back to Blogs</a>
              </div>
            </div>
          </div>
        </div>

        <div class="app-content">
          <div class="container-fluid">
            <div class="row">
              <div class="col-12">
                <div class="card card-primary card-outline mb-4">
                  <div class="card-header"><div class="card-title">Blog Properties</div></div>
                  <div class="card-body">
                    <div class="mb-3">
                      <label class="form-label">ID</label>
                      <input type="text" class="form-control" value="{{blog.id}}" readonly />
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Title</label>
                      <input
                        type="text"
                        class="form-control"
                        id="blogTitle"
                        value="{{blog.title}}"
                        readonly
                      />
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Slug</label>
                      <input
                        type="text"
                        class="form-control"
                        id="blogSlug"
                        value="{{blog.slug}}"
                        readonly
                      />
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Excerpt</label>
                      <textarea class="form-control" id="blogExcerpt" rows="3" readonly>{{blog.excerpt}}</textarea>
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Content</label>
                      <textarea class="form-control" id="blogContent" rows="8" readonly>{{blog.content}}</textarea>
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Featured Image</label>
                      <input
                        type="text"
                        class="form-control"
                        id="featuredImageUrl"
                        value="{{blog.featuredImage}}"
                        readonly
                      />
                      {{#if blog.featuredImage}}
                        <img
                          src="{{blog.featuredImage}}"
                          alt="Featured image"
                          id="featuredImagePreview"
                          class="img-thumbnail mt-2"
                          style="max-width: 220px"
                        />
                      {{else}}
                        <img
                          src=""
                          alt="Featured image"
                          id="featuredImagePreview"
                          class="img-thumbnail mt-2 d-none"
                          style="max-width: 220px"
                        />
                      {{/if}}

                      <div id="imageUploadAlert" class="alert d-none mt-3" role="alert"></div>

                      <div class="mt-3">
                        <label for="featuredImageFile" class="form-label">Upload New Featured Image</label>
                        <input
                          type="file"
                          class="form-control"
                          id="featuredImageFile"
                          accept="image/*"
                        />
                        <button type="button" class="btn btn-primary mt-2" id="uploadFeaturedImageBtn">
                          Upload Featured Image
                        </button>
                      </div>
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Meta Title</label>
                      <input
                        type="text"
                        class="form-control"
                        id="blogMetaTitle"
                        value="{{blog.metaTitle}}"
                        readonly
                      />
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Meta Description</label>
                      <textarea class="form-control" id="blogMetaDescription" rows="3" readonly>{{blog.metaDescription}}</textarea>
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Meta Keywords</label>
                      <input
                        type="text"
                        class="form-control"
                        id="blogMetaKeywords"
                        value="{{blog.metaKeywords}}"
                        readonly
                      />
                    </div>

                    <div class="row">
                      <div class="col-md-6 mb-3">
                        <label class="form-label">Status</label>
                        <input
                          type="text"
                          class="form-control"
                          id="blogStatus"
                          value="{{blog.status}}"
                          readonly
                        />
                      </div>
                      <div class="col-md-6 mb-3">
                        <label class="form-label">Is Featured</label>
                        <input
                          type="text"
                          class="form-control"
                          id="blogIsFeatured"
                          value="{{blog.isFeatured}}"
                          readonly
                        />
                      </div>
                    </div>

                    <div class="row">
                      <div class="col-md-6 mb-3">
                        <label class="form-label">Published At</label>
                        <input
                          type="text"
                          class="form-control"
                          id="blogPublishedAt"
                          value="{{blog.publishedAt}}"
                          readonly
                        />
                      </div>
                      <div class="col-md-6 mb-3">
                        <label class="form-label">Category</label>
                        <input
                          type="text"
                          class="form-control"
                          id="blogCategoryName"
                          value="{{blog.category.name}}"
                          readonly
                        />
                        <input type="hidden" id="blogCategoryId" value="{{blog.category.id}}" />
                      </div>
                    </div>

                    <div class="row">
                      <div class="col-md-6 mb-3">
                        <label class="form-label">View Count</label>
                        <input
                          type="text"
                          class="form-control"
                          id="blogViewCount"
                          value="{{blog.viewCount}}"
                          readonly
                        />
                      </div>
                      <div class="col-md-6 mb-3">
                        <label class="form-label">Reading Time (minutes)</label>
                        <input
                          type="text"
                          class="form-control"
                          id="blogReadingTime"
                          value="{{blog.readingTime}}"
                          readonly
                        />
                      </div>
                    </div>

                    <div class="mt-3">
                      <button type="button" class="btn btn-success" id="updateBlogBtn">Update Blog</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
      <!--end::App Main-->
