<!doctype html>
<html lang="en">
  <!--begin::Head-->
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>AdminLTE 4 | General Form Elements</title>
    <!--begin::Accessibility Meta Tags-->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#007bff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1a1a" media="(prefers-color-scheme: dark)" />
    <!--end::Accessibility Meta Tags-->
    <!--begin::Primary Meta Tags-->
    <meta name="title" content="AdminLTE 4 | General Form Elements" />
    <meta name="author" content="ColorlibHQ" />
    <meta
      name="description"
      content="AdminLTE is a Free Bootstrap 5 Admin Dashboard, 30 example pages using Vanilla JS. Fully accessible with WCAG 2.1 AA compliance."
    />
    <meta
      name="keywords"
      content="bootstrap 5, bootstrap, bootstrap 5 admin dashboard, bootstrap 5 dashboard, bootstrap 5 charts, bootstrap 5 calendar, bootstrap 5 datepicker, bootstrap 5 tables, bootstrap 5 datatable, vanilla js datatable, colorlibhq, colorlibhq dashboard, colorlibhq admin dashboard, accessible admin panel, WCAG compliant"
    />
    <!--end::Primary Meta Tags-->
    <!--begin::Accessibility Features-->
    <!-- Skip links will be dynamically added by accessibility.js -->
    <meta name="supported-color-schemes" content="light dark" />
    <link rel="preload" href="/css/admin/adminlte.css" as="style" />
    <!--end::Accessibility Features-->
    <!--begin::Fonts-->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@fontsource/source-sans-3@5.0.12/index.css"
      integrity="sha256-tXJfXfp6Ewt1ilPzLDtQnJV4hclT9XuaZUKyUvmyr+Q="
      crossorigin="anonymous"
      media="print"
      onload="this.media='all'"
    />
    <!--end::Fonts-->
    <!--begin::Third Party Plugin(OverlayScrollbars)-->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/styles/overlayscrollbars.min.css"
      crossorigin="anonymous"
    />
    <!--end::Third Party Plugin(OverlayScrollbars)-->
    <!--begin::Third Party Plugin(Bootstrap Icons)-->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
      crossorigin="anonymous"
    />
    <!--end::Third Party Plugin(Bootstrap Icons)-->
    <!--begin::Required Plugin(AdminLTE)-->
    <link rel="stylesheet" href="/css/admin/adminlte.css" />
    <!--end::Required Plugin(AdminLTE)-->
  </head>
  <!--end::Head-->
  <!--begin::Body-->
  <body class="layout-fixed sidebar-expand-lg sidebar-open bg-body-tertiary">
    <!--begin::App Wrapper-->
    <div class="app-wrapper">
      <!--begin::Header-->
      {{> adminheader}}

      <!--end::Header-->
      <!--begin::Sidebar-->
        {{> adminsidebar}}
      <!--end::Sidebar-->
      <!--begin::App Main-->
      <main class="app-main">
        <div class="app-content-header">
          <div class="container-fluid">
            <div class="row align-items-center">
              <div class="col-sm-6"><h3 class="mb-0">Blog Detail</h3></div>
              <div class="col-sm-6 text-sm-end mt-2 mt-sm-0">
                <a href="/admin/blogs" class="btn btn-outline-secondary btn-sm">Back to Blogs</a>
              </div>
            </div>
          </div>
        </div>

        <div class="app-content">
          <div class="container-fluid">
            <div class="row">
              <div class="col-12">
                <div class="card card-primary card-outline mb-4">
                  <div class="card-header"><div class="card-title">Blog Properties</div></div>
                  <div class="card-body">
                    <div class="mb-3">
                      <label class="form-label">ID</label>
                      <input type="text" class="form-control" value="{{blog.id}}" readonly />
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Title</label>
                      <input
                        type="text"
                        class="form-control"
                        id="blogTitle"
                        value="{{blog.title}}"
                        readonly
                      />
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Slug</label>
                      <input
                        type="text"
                        class="form-control"
                        id="blogSlug"
                        value="{{blog.slug}}"
                        readonly
                      />
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Excerpt</label>
                      <textarea class="form-control" id="blogExcerpt" rows="3" readonly>{{blog.excerpt}}</textarea>
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Content</label>
                      <textarea class="form-control" id="blogContent" rows="8" readonly>{{blog.content}}</textarea>
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Featured Image</label>
                      <input
                        type="text"
                        class="form-control"
                        id="featuredImageUrl"
                        value="{{blog.featuredImage}}"
                        readonly
                      />
                      {{#if blog.featuredImage}}
                        <img
                          src="{{blog.featuredImage}}"
                          alt="Featured image"
                          id="featuredImagePreview"
                          class="img-thumbnail mt-2"
                          style="max-width: 220px"
                        />
                      {{else}}
                        <img
                          src=""
                          alt="Featured image"
                          id="featuredImagePreview"
                          class="img-thumbnail mt-2 d-none"
                          style="max-width: 220px"
                        />
                      {{/if}}

                      <div id="imageUploadAlert" class="alert d-none mt-3" role="alert"></div>

                      <div class="mt-3">
                        <label for="featuredImageFile" class="form-label">Upload New Featured Image</label>
                        <input
                          type="file"
                          class="form-control"
                          id="featuredImageFile"
                          accept="image/*"
                        />
                        <button type="button" class="btn btn-primary mt-2" id="uploadFeaturedImageBtn">
                          Upload Featured Image
                        </button>
                      </div>
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Meta Title</label>
                      <input
                        type="text"
                        class="form-control"
                        id="blogMetaTitle"
                        value="{{blog.metaTitle}}"
                        readonly
                      />
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Meta Description</label>
                      <textarea class="form-control" id="blogMetaDescription" rows="3" readonly>{{blog.metaDescription}}</textarea>
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Meta Keywords</label>
                      <input
                        type="text"
                        class="form-control"
                        id="blogMetaKeywords"
                        value="{{blog.metaKeywords}}"
                        readonly
                      />
                    </div>

                    <div class="row">
                      <div class="col-md-6 mb-3">
                        <label class="form-label">Status</label>
                        <input
                          type="text"
                          class="form-control"
                          id="blogStatus"
                          value="{{blog.status}}"
                          readonly
                        />
                      </div>
                      <div class="col-md-6 mb-3">
                        <label class="form-label">Is Featured</label>
                        <input
                          type="text"
                          class="form-control"
                          id="blogIsFeatured"
                          value="{{blog.isFeatured}}"
                          readonly
                        />
                      </div>
                    </div>

                    <div class="row">
                      <div class="col-md-6 mb-3">
                        <label class="form-label">Published At</label>
                        <input
                          type="text"
                          class="form-control"
                          id="blogPublishedAt"
                          value="{{blog.publishedAt}}"
                          readonly
                        />
                      </div>
                      <div class="col-md-6 mb-3">
                        <label class="form-label">Category</label>
                        <select class="form-select" id="blogCategoryId" name="categoryId">
                          {{#each categories}}
                            <option
                              value="{{this.id}}"
                              {{#if (eq this.id ../blog.category.id)}}selected{{/if}}
                            >{{this.name}}</option>
                          {{/each}}
                        </select>
                      </div>
                    </div>

                    <div class="row">
                      <div class="col-md-6 mb-3">
                        <label class="form-label">View Count</label>
                        <input
                          type="text"
                          class="form-control"
                          id="blogViewCount"
                          value="{{blog.viewCount}}"
                          readonly
                        />
                      </div>
                      <div class="col-md-6 mb-3">
                        <label class="form-label">Reading Time (minutes)</label>
                        <input
                          type="text"
                          class="form-control"
                          id="blogReadingTime"
                          value="{{blog.readingTime}}"
                          readonly
                        />
                      </div>
                    </div>

                    <div class="mt-3">
                      <button type="button" class="btn btn-success" id="updateBlogBtn">Update Blog</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
      <!--end::App Main-->
      <!--begin::Footer-->
       {{> adminfooter}}
      <!--end::Footer-->
    </div>
    <!--end::App Wrapper-->
    <!--begin::Script-->
    <!--begin::Third Party Plugin(OverlayScrollbars)-->
    <script
      src="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/browser/overlayscrollbars.browser.es6.min.js"
      crossorigin="anonymous"
    ></script>
    <!--end::Third Party Plugin(OverlayScrollbars)--><!--begin::Required Plugin(popperjs for Bootstrap 5)-->
    <script
      src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
      crossorigin="anonymous"
    ></script>
    <!--end::Required Plugin(popperjs for Bootstrap 5)--><!--begin::Required Plugin(Bootstrap 5)-->
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.min.js"
      crossorigin="anonymous"
    ></script>
    <!--end::Required Plugin(Bootstrap 5)--><!--begin::Required Plugin(AdminLTE)-->
    <script src="/scripts/admin/js/adminlte.js"></script>
    <!--end::Required Plugin(AdminLTE)--><!--begin::OverlayScrollbars Configure-->
    <script>
      const SELECTOR_SIDEBAR_WRAPPER = '.sidebar-wrapper';
      const Default = {
        scrollbarTheme: 'os-theme-light',
        scrollbarAutoHide: 'leave',
        scrollbarClickScroll: true,
      };
      document.addEventListener('DOMContentLoaded', function () {
        const sidebarWrapper = document.querySelector(SELECTOR_SIDEBAR_WRAPPER);
        if (sidebarWrapper && OverlayScrollbarsGlobal?.OverlayScrollbars !== undefined) {
          OverlayScrollbarsGlobal.OverlayScrollbars(sidebarWrapper, {
            scrollbars: {
              theme: Default.scrollbarTheme,
              autoHide: Default.scrollbarAutoHide,
              clickScroll: Default.scrollbarClickScroll,
            },
          });
        }
      });

      async function uploadFile(file) {
        const response = await fetch('/admin/blogs/upload-url', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ contentType: file.type }),
        });

        if (!response.ok) {
          throw new Error('Could not get upload url.');
        }

        const { url } = await response.json();

        const uploadResponse = await fetch(url, {
          method: 'PUT',
          headers: {
            'Content-Type': file.type,
          },
          body: file,
        });

        if (!uploadResponse.ok) {
          throw new Error('Could not upload featured image.');
        }

        return uploadResponse.url.split('?')[0];
      }

      document.addEventListener('DOMContentLoaded', function () {
        const uploadButton = document.getElementById('uploadFeaturedImageBtn');
        const fileInput = document.getElementById('featuredImageFile');
        const alertBox = document.getElementById('imageUploadAlert');
        const imageUrlInput = document.getElementById('featuredImageUrl');
        const imagePreview = document.getElementById('featuredImagePreview');
        const updateBlogButton = document.getElementById('updateBlogBtn');
        const titleInput = document.getElementById('blogTitle');
        const slugInput = document.getElementById('blogSlug');
        const excerptInput = document.getElementById('blogExcerpt');
        const contentInput = document.getElementById('blogContent');
        const metaTitleInput = document.getElementById('blogMetaTitle');
        const metaDescriptionInput = document.getElementById('blogMetaDescription');
        const metaKeywordsInput = document.getElementById('blogMetaKeywords');
        const statusInput = document.getElementById('blogStatus');
        const isFeaturedInput = document.getElementById('blogIsFeatured');
        const publishedAtInput = document.getElementById('blogPublishedAt');
        const categoryIdInput = document.getElementById('blogCategoryId');
        const viewCountInput = document.getElementById('blogViewCount');
        const readingTimeInput = document.getElementById('blogReadingTime');

        if (
          !uploadButton ||
          !fileInput ||
          !alertBox ||
          !imageUrlInput ||
          !imagePreview ||
          !updateBlogButton ||
          !titleInput ||
          !slugInput ||
          !excerptInput ||
          !contentInput ||
          !metaTitleInput ||
          !metaDescriptionInput ||
          !metaKeywordsInput ||
          !statusInput ||
          !isFeaturedInput ||
          !publishedAtInput ||
          !categoryIdInput ||
          !viewCountInput ||
          !readingTimeInput
        ) {
          return;
        }

        const showAlert = (message, type) => {
          alertBox.textContent = message;
          alertBox.classList.remove('d-none', 'alert-success', 'alert-danger');
          alertBox.classList.add(type === 'success' ? 'alert-success' : 'alert-danger');
        };

        const buildPayload = (featuredImageValue) => {
          const isFeaturedValue = String(isFeaturedInput.value || '')
            .trim()
            .toLowerCase();

          return {
            title: String(titleInput.value || '').trim(),
            slug: String(slugInput.value || '').trim(),
            excerpt: String(excerptInput.value || '').trim(),
            content: String(contentInput.value || '').trim(),
            featuredImage: String(featuredImageValue || '').trim(),
            metaTitle: String(metaTitleInput.value || '').trim(),
            metaDescription: String(metaDescriptionInput.value || '').trim(),
            metaKeywords: String(metaKeywordsInput.value || '')
              .split(',')
              .map((item) => item.trim())
              .filter(Boolean),
            status: String(statusInput.value || '').trim(),
            isFeatured: isFeaturedValue === 'true' || isFeaturedValue === '1',
            publishedAt: String(publishedAtInput.value || '').trim(),
            categoryId: String(categoryIdInput.value || '').trim(),
            viewCount: Number(viewCountInput.value || 0),
            readingTime: Number(readingTimeInput.value || 0),
          };
        };

        const updateBlog = async (payload) => {
          const updateResponse = await fetch('/admin/blogs/{{blog.id}}', {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
            },
            body: JSON.stringify(payload),
          });

          if (!updateResponse.ok) {
            const responseText = await updateResponse.text();
            let responseBody = null;

            if (responseText) {
              try {
                responseBody = JSON.parse(responseText);
              } catch (error) {
                responseBody = null;
              }
            }

            const errorMessage =
              responseBody?.message ||
              responseBody?.error ||
              updateResponse.statusText ||
              'Could not update blog.';

            throw new Error(Array.isArray(errorMessage) ? errorMessage.join(', ') : errorMessage);
          }
        };

        updateBlogButton.addEventListener('click', async function () {
          updateBlogButton.disabled = true;
          alertBox.classList.add('d-none');

          try {
            const payload = buildPayload(imageUrlInput.value);
            await updateBlog(payload);
            showAlert('Blog updated successfully.', 'success');
          } catch (error) {
            const message = error instanceof Error ? error.message : 'Unexpected error occurred.';
            showAlert(message, 'error');
          } finally {
            updateBlogButton.disabled = false;
          }
        });

        uploadButton.addEventListener('click', async function () {
          const selectedFile = fileInput.files && fileInput.files[0];

          if (!selectedFile) {
            showAlert('Please select an image file first.', 'error');
            return;
          }

          uploadButton.disabled = true;
          updateBlogButton.disabled = true;
          alertBox.classList.add('d-none');

          try {
            const uploadedImageUrl = await uploadFile(selectedFile);
            const payload = buildPayload(uploadedImageUrl);
            await updateBlog(payload);

            imageUrlInput.value = uploadedImageUrl;
            imagePreview.setAttribute('src', uploadedImageUrl);
            imagePreview.classList.remove('d-none');
            fileInput.value = '';
            showAlert('Featured image updated successfully.', 'success');
          } catch (error) {
            const message = error instanceof Error ? error.message : 'Unexpected error occurred.';
            showAlert(message, 'error');
          } finally {
            uploadButton.disabled = false;
            updateBlogButton.disabled = false;
          }
        });
      });
    </script>
    <!--end::OverlayScrollbars Configure-->
    <!--end::Script-->
  </body>
  <!--end::Body-->
</html>
