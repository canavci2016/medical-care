<!doctype html>
<html lang='en'>
  <head>
    <meta http-equiv='Content-Type' content='text/html; charset=utf-8' />
    <title>AdminLTE 4 | Hair Result Detail</title>
    <meta name='viewport' content='width=device-width, initial-scale=1.0, user-scalable=yes' />
    <meta name='color-scheme' content='light dark' />
    <meta name='theme-color' content='#007bff' media='(prefers-color-scheme: light)' />
    <meta name='theme-color' content='#1a1a1a' media='(prefers-color-scheme: dark)' />
    <meta name='supported-color-schemes' content='light dark' />
    <link rel='preload' href='/css/admin/adminlte.css' as='style' />
    <link
      rel='stylesheet'
      href='https://cdn.jsdelivr.net/npm/@fontsource/source-sans-3@5.0.12/index.css'
      integrity='sha256-tXJfXfp6Ewt1ilPzLDtQnJV4hclT9XuaZUKyUvmyr+Q='
      crossorigin='anonymous'
      media='print'
      onload="this.media='all'"
    />
    <link
      rel='stylesheet'
      href='https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/styles/overlayscrollbars.min.css'
      crossorigin='anonymous'
    />
    <link
      rel='stylesheet'
      href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css'
      crossorigin='anonymous'
    />
    <link rel='stylesheet' href='/css/admin/adminlte.css' />
  </head>
  <body class='layout-fixed sidebar-expand-lg sidebar-open bg-body-tertiary'>
    <div class='app-wrapper'>
      {{> adminheader}}
      {{> adminsidebar}}

      <main class='app-main'>
        <div class='app-content-header'>
          <div class='container-fluid'>
            <div class='row align-items-center'>
              <div class='col-sm-6'><h3 class='mb-0'>Hair Result Detail</h3></div>
              <div class='col-sm-6 text-sm-end mt-2 mt-sm-0'>
                <a href='/admin/hospital-hair-results' class='btn btn-outline-secondary btn-sm'>Back to List</a>
              </div>
            </div>
          </div>
        </div>

        <div class='app-content'>
          <div class='container-fluid'>
            <div class='row'>
              <div class='col-12'>
                <div class='card card-primary card-outline mb-4'>
                  <div class='card-header'><div class='card-title'>Result Properties</div></div>
                  <div class='card-body'>
                    <div class='mb-3'>
                      <label class='form-label'>ID</label>
                      <input type='text' class='form-control' id='resultId' value='{{result.id}}' readonly />
                    </div>

                    <div class='mb-3'>
                      <label for='hospitalId' class='form-label'>Hospital</label>
                      <select class='form-select' id='hospitalId' name='hospitalId'>
                        {{#each hospitals}}
                          <option value='{{this.id}}' {{#if (eq this.id ../result.hospitalId)}}selected{{/if}}>{{this.name}}</option>
                        {{/each}}
                      </select>
                    </div>

                    <div class='row'>
                      <div class='col-md-6 mb-3'>
                        <label for='procedureType' class='form-label'>Procedure Type</label>
                        <select class='form-select' id='procedureType'>
                          {{#each procedureTypes}}
                            <option value='{{this}}' {{#if (eq this ../result.procedureType)}}selected{{/if}}>{{this}}</option>
                          {{/each}}
                        </select>
                      </div>
                      <div class='col-md-6 mb-3'>
                        <label for='technique' class='form-label'>Technique</label>
                        <select class='form-select' id='technique'>
                          {{#each techniques}}
                            <option value='{{this}}' {{#if (eq this ../result.technique)}}selected{{/if}}>{{this}}</option>
                          {{/each}}
                        </select>
                      </div>
                    </div>

                    <div class='row'>
                      <div class='col-md-6 mb-3'>
                        <label for='graftCount' class='form-label'>Graft Count</label>
                        <input type='number' min='0' class='form-control' id='graftCount' value='{{result.graftCount}}' />
                      </div>
                      <div class='col-md-6 mb-3'>
                        <label for='monthsAfter' class='form-label'>Months After</label>
                        <input type='number' min='0' class='form-control' id='monthsAfter' value='{{result.monthsAfter}}' />
                      </div>
                    </div>

                    <div class='mb-3'>
                      <label for='availableMonths' class='form-label'>Available Months (comma separated)</label>
                      <input type='text' class='form-control' id='availableMonths' value='{{availableMonthsText}}' />
                    </div>

                    <div class='row'>
                      <div class='col-md-6 mb-3'>
                        <label for='operationDate' class='form-label'>Operation Date</label>
                        <input type='date' class='form-control' id='operationDate' value='{{result.operationDate}}' />
                      </div>
                      <div class='col-md-6 mb-3'>
                        <label for='patientAgeRange' class='form-label'>Patient Age Range</label>
                        <select class='form-select' id='patientAgeRange'>
                          <option value='20-25' {{#if (eq '20-25' result.patientAgeRange)}}selected{{/if}}>20-25</option>
                          <option value='25-30' {{#if (eq '25-30' result.patientAgeRange)}}selected{{/if}}>25-30</option>
                          <option value='30-35' {{#if (eq '30-35' result.patientAgeRange)}}selected{{/if}}>30-35</option>
                          <option value='35-40' {{#if (eq '35-40' result.patientAgeRange)}}selected{{/if}}>35-40</option>
                          <option value='40-45' {{#if (eq '40-45' result.patientAgeRange)}}selected{{/if}}>40-45</option>
                          <option value='45-50' {{#if (eq '45-50' result.patientAgeRange)}}selected{{/if}}>45-50</option>
                          <option value='50-55' {{#if (eq '50-55' result.patientAgeRange)}}selected{{/if}}>50-55</option>
                          <option value='55-60' {{#if (eq '55-60' result.patientAgeRange)}}selected{{/if}}>55-60</option>
                        </select>
                      </div>
                    </div>

                    <div class='mb-3'>
                      <label for='original_url' class='form-label'>Original URL (Patient History)</label>
                      <input type='url' class='form-control' id='original_url' value='{{result.original_url}}' />
                    </div>

                    <div class='form-check mb-2'>
                      <input class='form-check-input' type='checkbox' id='verified' {{#if result.verified}}checked{{/if}} />
                      <label class='form-check-label' for='verified'>Verified</label>
                    </div>
                    <div class='form-check mb-2'>
                      <input class='form-check-input' type='checkbox' id='consentReceived' {{#if result.consentReceived}}checked{{/if}} />
                      <label class='form-check-label' for='consentReceived'>Consent Received</label>
                    </div>
                    <div class='form-check mb-3'>
                      <input class='form-check-input' type='checkbox' id='isPublic' {{#if result.isPublic}}checked{{/if}} />
                      <label class='form-check-label' for='isPublic'>Public</label>
                    </div>

                    <div class='mb-3'>
                      <label for='doctorNotes' class='form-label'>Doctor Notes</label>
                      <textarea class='form-control' id='doctorNotes' rows='3'>{{result.doctorNotes}}</textarea>
                    </div>

                    <div class='mb-3'>
                      <label for='patientStory' class='form-label'>Patient Story</label>
                      <textarea class='form-control' id='patientStory' rows='3'>{{result.patientStory}}</textarea>
                    </div>

                    <div class='mb-3'>
                      <label for='resultImages' class='form-label'>Attached Images</label>
                      <input
                        type='file'
                        class='form-control'
                        id='resultImages'
                        accept='image/*'
                        multiple
                      />
                      <button
                        type='button'
                        class='btn btn-outline-primary btn-sm mt-2'
                        id='uploadResultImagesBtn'
                      >Upload Selected Images</button>
                      <div id='resultImagesPreview' class='mt-3 d-flex flex-wrap gap-2'></div>
                    </div>

                    <div id='updateResultAlert' class='alert d-none' role='alert'></div>

                    <div id='imageDetailsModal' class='modal' tabindex='-1'>
                      <div class='modal-dialog'>
                        <div class='modal-content'>
                          <div class='modal-header'>
                            <h5 class='modal-title'>Image Properties</h5>
                            <button type='button' class='btn-close' data-bs-dismiss='modal' aria-label='Close'></button>
                          </div>
                          <div class='modal-body'>
                            <div class='mb-3'>
                              <label for='imageMonth' class='form-label'>Month</label>
                              <input type='number' class='form-control' id='imageMonth' min='0' value='0' />
                            </div>
                            <div class='mb-3'>
                              <label for='imageAngle' class='form-label'>Angle</label>
                              <select class='form-select' id='imageAngle'>
                                <option value=''>None</option>
                                <option value='front'>Front</option>
                                <option value='left'>Left</option>
                                <option value='right'>Right</option>
                                <option value='top'>Top</option>
                              </select>
                            </div>
                            <div class='mb-3'>
                              <label for='imageLighting' class='form-label'>Lighting</label>
                              <input type='text' class='form-control' id='imageLighting' placeholder='e.g., natural, fluorescent' />
                            </div>
                            <div class='form-check mb-2'>
                              <input class='form-check-input' type='checkbox' id='imageIsBefore' />
                              <label class='form-check-label' for='imageIsBefore'>Before</label>
                            </div>
                            <div class='form-check mb-2'>
                              <input class='form-check-input' type='checkbox' id='imageIsAfter' />
                              <label class='form-check-label' for='imageIsAfter'>After</label>
                            </div>
                            <div class='form-check mb-3'>
                              <input class='form-check-input' type='checkbox' id='imageWatermarked' />
                              <label class='form-check-label' for='imageWatermarked'>Watermarked</label>
                            </div>
                          </div>
                          <div class='modal-footer'>
                            <button type='button' class='btn btn-secondary' data-bs-dismiss='modal'>Close</button>
                            <button type='button' class='btn btn-primary' id='saveImageDetailsBtn'>Save Changes</button>
                          </div>
                        </div>
                      </div>
                    </div>

                    <div class='d-flex gap-2'>
                      <button type='button' class='btn btn-success' id='updateResultBtn'>Update Result</button>
                      <button type='button' class='btn btn-outline-danger' id='deleteResultBtn'>Delete Result</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>

      {{> adminfooter}}
    </div>

    <script
      src='https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/browser/overlayscrollbars.browser.es6.min.js'
      crossorigin='anonymous'
    ></script>
    <script
      src='https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js'
      crossorigin='anonymous'
    ></script>
    <script
      src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.min.js'
      crossorigin='anonymous'
    ></script>
    <script src='/scripts/admin/js/adminlte.js'></script>
    <script>
      const SELECTOR_SIDEBAR_WRAPPER = '.sidebar-wrapper';
      const Default = {
        scrollbarTheme: 'os-theme-light',
        scrollbarAutoHide: 'leave',
        scrollbarClickScroll: true,
      };
      document.addEventListener('DOMContentLoaded', function () {
        const sidebarWrapper = document.querySelector(SELECTOR_SIDEBAR_WRAPPER);
        if (sidebarWrapper && OverlayScrollbarsGlobal?.OverlayScrollbars !== undefined) {
          OverlayScrollbarsGlobal.OverlayScrollbars(sidebarWrapper, {
            scrollbars: {
              theme: Default.scrollbarTheme,
              autoHide: Default.scrollbarAutoHide,
              clickScroll: Default.scrollbarClickScroll,
            },
          });
        }
      });

      document.addEventListener('DOMContentLoaded', function () {
        const updateButton = document.getElementById('updateResultBtn');
        const deleteButton = document.getElementById('deleteResultBtn');
        const uploadImagesButton = document.getElementById('uploadResultImagesBtn');
        const resultImagesInput = document.getElementById('resultImages');
        const resultImagesPreview = document.getElementById('resultImagesPreview');
        const alertBox = document.getElementById('updateResultAlert');
        const resultIdInput = document.getElementById('resultId');
        const uploadedImages = (({{{json result.images}}}) || []).map((item) => ({
          id: item.id,
          imageUrl: item.imageUrl,
          month: item.month,
          isBefore: item.isBefore,
          isAfter: item.isAfter,
          angle: item.angle,
          lighting: item.lighting,
          watermarked: item.watermarked,
        }));

        if (
          !updateButton ||
          !deleteButton ||
          !uploadImagesButton ||
          !resultImagesInput ||
          !resultImagesPreview ||
          !alertBox ||
          !resultIdInput
        ) {
          return;
        }

        const renderImagePreview = () => {
          resultImagesPreview.innerHTML = '';

          uploadedImages.forEach((img, index) => {
            const wrapper = document.createElement('div');
            wrapper.className = 'position-relative';
            wrapper.style.width = '120px';

            const image = document.createElement('img');
            image.src = img.imageUrl;
            image.alt = 'Result image';
            image.className = 'img-thumbnail';
            image.style.width = '110px';
            image.style.height = '110px';
            image.style.objectFit = 'cover';

            const infoButton = document.createElement('button');
            infoButton.type = 'button';
            infoButton.className = 'btn btn-sm btn-info position-absolute top-0 start-0';
            infoButton.textContent = 'ℹ';
            infoButton.style.padding = '2px 6px';
            infoButton.addEventListener('click', function () {
              showImageDetailsModal(img, index);
            });

            const removeButton = document.createElement('button');
            removeButton.type = 'button';
            removeButton.className = 'btn btn-sm btn-danger position-absolute top-0 end-0';
            removeButton.textContent = '×';
            removeButton.addEventListener('click', function () {
              uploadedImages.splice(index, 1);
              renderImagePreview();
            });

            const monthLabel = document.createElement('small');
            monthLabel.className = 'position-absolute bottom-0 start-0 bg-dark text-white p-1';
            monthLabel.textContent = `M${img.month}`;
            monthLabel.style.fontSize = '10px';

            wrapper.appendChild(image);
            wrapper.appendChild(infoButton);
            wrapper.appendChild(removeButton);
            wrapper.appendChild(monthLabel);
            resultImagesPreview.appendChild(wrapper);
          });
        };

        const uploadFile = async (file) => {
          const response = await fetch('/admin/hospital-hair-results/upload-url', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ contentType: file.type }),
          });

          if (!response.ok) {
            throw new Error('Could not get upload url.');
          }

          const { url } = await response.json();

          const uploadResponse = await fetch(url, {
            method: 'PUT',
            headers: {
              'Content-Type': file.type,
            },
            body: file,
          });

          if (!uploadResponse.ok) {
            throw new Error('Could not upload image.');
          }

          return uploadResponse.url.split('?')[0];
        };

        const buildPayload = () => {
          const availableMonths = String(document.getElementById('availableMonths').value || '')
            .split(',')
            .map((item) => parseInt(item.trim(), 10))
            .filter((item) => !Number.isNaN(item));

          return {
            hospitalId: String(document.getElementById('hospitalId').value || '').trim(),
            procedureType: String(document.getElementById('procedureType').value || '').trim(),
            technique: String(document.getElementById('technique').value || '').trim(),
            graftCount: Number(document.getElementById('graftCount').value || 0),
            monthsAfter: Number(document.getElementById('monthsAfter').value || 0),
            availableMonths,
            operationDate: String(document.getElementById('operationDate').value || '').trim() || undefined,
            patientAgeRange: String(document.getElementById('patientAgeRange').value || '').trim() || undefined,
            original_url: String(document.getElementById('original_url').value || '').trim() || undefined,
            verified: document.getElementById('verified').checked,
            consentReceived: document.getElementById('consentReceived').checked,
            isPublic: document.getElementById('isPublic').checked,
            doctorNotes: String(document.getElementById('doctorNotes').value || '').trim() || undefined,
            patientStory: String(document.getElementById('patientStory').value || '').trim() || undefined,
            images: uploadedImages.map((img) => ({
              imageUrl: img.imageUrl,
              month: img.month,
              isBefore: img.isBefore,
              isAfter: img.isAfter,
              angle: img.angle || undefined,
              lighting: img.lighting || undefined,
              watermarked: img.watermarked,
            })),
          };
        };

        const showAlert = (message, type) => {
          alertBox.textContent = message;
          alertBox.classList.remove('d-none', 'alert-success', 'alert-danger');
          alertBox.classList.add(type === 'success' ? 'alert-success' : 'alert-danger');
        };

        let currentEditingImageIndex = -1;

        const showImageDetailsModal = (img, index) => {
          currentEditingImageIndex = index;
          document.getElementById('imageMonth').value = img.month || 0;
          document.getElementById('imageAngle').value = img.angle || '';
          document.getElementById('imageLighting').value = img.lighting || '';
          document.getElementById('imageIsBefore').checked = img.isBefore || false;
          document.getElementById('imageIsAfter').checked = img.isAfter || false;
          document.getElementById('imageWatermarked').checked = img.watermarked || false;

          const modal = new bootstrap.Modal(document.getElementById('imageDetailsModal'));
          modal.show();
        };

        const saveImageDetailsBtn = document.getElementById('saveImageDetailsBtn');
        if (saveImageDetailsBtn) {
          saveImageDetailsBtn.addEventListener('click', function () {
            if (currentEditingImageIndex !== -1) {
              uploadedImages[currentEditingImageIndex] = {
                ...uploadedImages[currentEditingImageIndex],
                month: Number(document.getElementById('imageMonth').value || 0),
                angle: document.getElementById('imageAngle').value || undefined,
                lighting: document.getElementById('imageLighting').value || undefined,
                isBefore: document.getElementById('imageIsBefore').checked,
                isAfter: document.getElementById('imageIsAfter').checked,
                watermarked: document.getElementById('imageWatermarked').checked,
              };
              renderImagePreview();
              const modalElement = document.getElementById('imageDetailsModal');
              const modal = bootstrap.Modal.getInstance(modalElement);
              if (modal) {
                modal.hide();
              }
            }
          });
        }

        const updateResult = async (payload) => {
          const response = await fetch(`/admin/hospital-hair-results/${resultIdInput.value}`, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
            },
            body: JSON.stringify(payload),
          });

          if (!response.ok) {
            const responseText = await response.text();
            let responseBody = null;

            if (responseText) {
              try {
                responseBody = JSON.parse(responseText);
              } catch (error) {
                responseBody = null;
              }
            }

            const errorMessage =
              responseBody?.message ||
              responseBody?.error ||
              response.statusText ||
              'Result could not be updated.';

            throw new Error(Array.isArray(errorMessage) ? errorMessage.join(', ') : errorMessage);
          }
        };

        renderImagePreview();

        uploadImagesButton.addEventListener('click', async function () {
          const selectedFiles = Array.from(resultImagesInput.files || []);

          if (selectedFiles.length === 0) {
            showAlert('Please select at least one image.', 'error');
            return;
          }

          uploadImagesButton.disabled = true;
          updateButton.disabled = true;
          alertBox.classList.add('d-none');

          try {
            const uploadedUrls = await Promise.all(selectedFiles.map((file) => uploadFile(file)));
            
            // Add newly uploaded images with default properties
            const newMonthValue = Number(document.getElementById('monthsAfter').value || 0);
            uploadedUrls.forEach((url) => {
              uploadedImages.push({
                imageUrl: url,
                month: newMonthValue,
                isBefore: false,
                isAfter: true,
                angle: undefined,
                lighting: undefined,
                watermarked: false,
              });
            });

            await updateResult(buildPayload());
            renderImagePreview();
            resultImagesInput.value = '';
            showAlert('Images uploaded and saved successfully.', 'success');
          } catch (error) {
            const message = error instanceof Error ? error.message : 'Unexpected error occurred.';
            showAlert(message, 'error');
          } finally {
            uploadImagesButton.disabled = false;
            updateButton.disabled = false;
          }
        });

        updateButton.addEventListener('click', async function () {
          updateButton.disabled = true;
          alertBox.classList.add('d-none');

          try {
            await updateResult(buildPayload());

            showAlert('Result updated successfully.', 'success');
          } catch (error) {
            const message = error instanceof Error ? error.message : 'Unexpected error occurred.';
            showAlert(message, 'error');
          } finally {
            updateButton.disabled = false;
          }
        });

        deleteButton.addEventListener('click', async function () {
          const confirmed = window.confirm('Are you sure you want to delete this result?');
          if (!confirmed) {
            return;
          }

          deleteButton.disabled = true;
          alertBox.classList.add('d-none');

          try {
            const response = await fetch(`/admin/hospital-hair-results/${resultIdInput.value}`, {
              method: 'DELETE',
              headers: {
                Accept: 'application/json',
              },
            });

            if (!response.ok) {
              throw new Error('Result could not be deleted.');
            }

            window.location.href = '/admin/hospital-hair-results';
          } catch (error) {
            const message = error instanceof Error ? error.message : 'Unexpected error occurred.';
            showAlert(message, 'error');
            deleteButton.disabled = false;
          }
        });
      });
    </script>
  </body>
</html>
