<!doctype html>
<html lang='en'>
  <head>
    <meta http-equiv='Content-Type' content='text/html; charset=utf-8' />
    <title>AdminLTE 4 | Hospital Detail</title>
    <meta name='viewport' content='width=device-width, initial-scale=1.0, user-scalable=yes' />
    <meta name='color-scheme' content='light dark' />
    <meta name='theme-color' content='#007bff' media='(prefers-color-scheme: light)' />
    <meta name='theme-color' content='#1a1a1a' media='(prefers-color-scheme: dark)' />
    <meta name='supported-color-schemes' content='light dark' />
    <link rel='preload' href='/css/admin/adminlte.css' as='style' />
    <link
      rel='stylesheet'
      href='https://cdn.jsdelivr.net/npm/@fontsource/source-sans-3@5.0.12/index.css'
      integrity='sha256-tXJfXfp6Ewt1ilPzLDtQnJV4hclT9XuaZUKyUvmyr+Q='
      crossorigin='anonymous'
      media='print'
      onload="this.media='all'"
    />
    <link
      rel='stylesheet'
      href='https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/styles/overlayscrollbars.min.css'
      crossorigin='anonymous'
    />
    <link
      rel='stylesheet'
      href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css'
      crossorigin='anonymous'
    />
    <link rel='stylesheet' href='/css/admin/adminlte.css' />
  </head>
  <body class='layout-fixed sidebar-expand-lg sidebar-open bg-body-tertiary'>
    <div class='app-wrapper'>
      {{> adminheader}}
      {{> adminsidebar}}

      <main class='app-main'>
        <div class='app-content-header'>
          <div class='container-fluid'>
            <div class='row align-items-center'>
              <div class='col-sm-6'><h3 class='mb-0'>Hospital Detail</h3></div>
              <div class='col-sm-6 text-sm-end mt-2 mt-sm-0'>
                <a href='/admin/hospitals' class='btn btn-outline-secondary btn-sm'>Back to List</a>
              </div>
            </div>
          </div>
        </div>

        <div class='app-content'>
          <div class='container-fluid'>
            <div class='row'>
              <div class='col-12'>
                <div class='card card-primary card-outline mb-4'>
                  <div class='card-header'><div class='card-title'>Hospital Properties</div></div>
                  <div class='card-body'>
                    <div class='mb-3'>
                      <label class='form-label'>ID</label>
                      <input type='text' class='form-control' id='hospitalId' value='{{hospital.id}}' readonly />
                    </div>

                    <div class='mb-3'>
                      <label for='name' class='form-label'>Name</label>
                      <input type='text' class='form-control' id='name' value='{{hospital.name}}' />
                    </div>

                    <div class='row'>
                      <div class='col-md-6 mb-3'>
                        <label for='city' class='form-label'>City</label>
                        <input type='text' class='form-control' id='city' value='{{hospital.city}}' />
                      </div>
                      <div class='col-md-6 mb-3'>
                        <label for='country' class='form-label'>Country</label>
                        <input type='text' class='form-control' id='country' value='{{hospital.country}}' />
                      </div>
                    </div>

                    <div class='mb-3'>
                      <label for='address' class='form-label'>Address</label>
                      <input type='text' class='form-control' id='address' value='{{hospital.address}}' />
                    </div>

                    <div class='row'>
                      <div class='col-md-6 mb-3'>
                        <label for='phone' class='form-label'>Phone</label>
                        <input type='text' class='form-control' id='phone' value='{{hospital.phone}}' />
                      </div>
                      <div class='col-md-6 mb-3'>
                        <label for='email' class='form-label'>Email</label>
                        <input type='email' class='form-control' id='email' value='{{hospital.email}}' />
                      </div>
                    </div>

                    <div class='mb-3'>
                      <label for='website' class='form-label'>Website</label>
                      <input type='url' class='form-control' id='website' value='{{hospital.website}}' />
                    </div>

                    <div class='mb-3'>
                      <label for='instagramUrl' class='form-label'>Instagram URL</label>
                      <input
                        type='url'
                        class='form-control'
                        id='instagramUrl'
                        value='{{hospital.instagramUrl}}'
                      />
                    </div>

                    <div class='mb-3'>
                      <label for='description' class='form-label'>Description</label>
                      <textarea class='form-control' id='description' rows='3'>{{hospital.description}}</textarea>
                    </div>

                    <div class='mb-3'>
                      <label for='coverImageUrl' class='form-label'>Cover Image URL</label>
                      <input
                        type='text'
                        class='form-control'
                        id='coverImageUrl'
                        value='{{hospital.coverImageUrl}}'
                        readonly
                      />
                      {{#if hospital.coverImageUrl}}
                        <img
                          src='{{hospital.coverImageUrl}}'
                          alt='Cover image preview'
                          id='coverImagePreview'
                          class='img-thumbnail mt-2'
                          style='max-width: 400px; max-height: 400px; object-fit: contain;'
                        />
                      {{else}}
                        <img
                          src=''
                          alt='Cover image preview'
                          id='coverImagePreview'
                          class='img-thumbnail mt-2 d-none'
                          style='max-width: 400px; max-height: 400px; object-fit: contain;'
                        />
                      {{/if}}

                      <div class='mt-3'>
                        <label for='coverImageFile' class='form-label'>Upload New Cover Image</label>
                        <input
                          type='file'
                          class='form-control'
                          id='coverImageFile'
                          accept='image/*'
                        />
                        <button
                          type='button'
                          class='btn btn-primary mt-2'
                          id='uploadCoverImageBtn'
                        >Upload Cover Image</button>
                      </div>
                    </div>

                    <div class='row'>
                      <div class='col-md-6 mb-3'>
                        <label for='rating' class='form-label'>Rating</label>
                        <input type='number' min='0' max='5' step='0.1' class='form-control' id='rating' value='{{hospital.rating}}' />
                      </div>
                      <div class='col-md-6 mb-3'>
                        <label for='reviewCount' class='form-label'>Review Count</label>
                        <input type='number' min='0' class='form-control' id='reviewCount' value='{{hospital.reviewCount}}' />
                      </div>
                    </div>

                    <div class='mb-3'>
                      <label for='techniques' class='form-label'>Techniques</label>
                      <select class='form-select' id='techniques' multiple>
                        {{#each techniquesOptions}}
                          <option value='{{this.value}}' {{#if this.selected}}selected{{/if}}>{{this.value}}</option>
                        {{/each}}
                      </select>
                    </div>

                    <div class='form-check mb-2'>
                      <input class='form-check-input' type='checkbox' id='isVerified' {{#if hospital.isVerified}}checked{{/if}} />
                      <label class='form-check-label' for='isVerified'>Verified</label>
                    </div>
                    <div class='form-check mb-3'>
                      <input class='form-check-input' type='checkbox' id='instagramVerified' {{#if hospital.instagramVerified}}checked{{/if}} />
                      <label class='form-check-label' for='instagramVerified'>Instagram Verified</label>
                    </div>

                    <div id='updateHospitalAlert' class='alert d-none' role='alert'></div>

                    <div class='d-flex gap-2'>
                      <button type='button' class='btn btn-success' id='updateHospitalBtn'>Update Hospital</button>
                      <button type='button' class='btn btn-outline-danger' id='deleteHospitalBtn'>Delete Hospital</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>

      {{> adminfooter}}
    </div>

    <script
      src='https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/browser/overlayscrollbars.browser.es6.min.js'
      crossorigin='anonymous'
    ></script>
    <script
      src='https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js'
      crossorigin='anonymous'
    ></script>
    <script
      src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.min.js'
      crossorigin='anonymous'
    ></script>
    <script src='/scripts/admin/js/adminlte.js'></script>
    <script>
      const SELECTOR_SIDEBAR_WRAPPER = '.sidebar-wrapper';
      const Default = {
        scrollbarTheme: 'os-theme-light',
        scrollbarAutoHide: 'leave',
        scrollbarClickScroll: true,
      };
      document.addEventListener('DOMContentLoaded', function () {
        const sidebarWrapper = document.querySelector(SELECTOR_SIDEBAR_WRAPPER);
        if (sidebarWrapper && OverlayScrollbarsGlobal?.OverlayScrollbars !== undefined) {
          OverlayScrollbarsGlobal.OverlayScrollbars(sidebarWrapper, {
            scrollbars: {
              theme: Default.scrollbarTheme,
              autoHide: Default.scrollbarAutoHide,
              clickScroll: Default.scrollbarClickScroll,
            },
          });
        }
      });

      document.addEventListener('DOMContentLoaded', function () {
        const uploadButton = document.getElementById('uploadCoverImageBtn');
        const coverImageFileInput = document.getElementById('coverImageFile');
        const coverImageUrlInput = document.getElementById('coverImageUrl');
        const coverImagePreview = document.getElementById('coverImagePreview');
        const updateButton = document.getElementById('updateHospitalBtn');
        const deleteButton = document.getElementById('deleteHospitalBtn');
        const alertBox = document.getElementById('updateHospitalAlert');
        const hospitalIdInput = document.getElementById('hospitalId');

        if (
          !uploadButton ||
          !coverImageFileInput ||
          !coverImageUrlInput ||
          !coverImagePreview ||
          !updateButton ||
          !deleteButton ||
          !alertBox ||
          !hospitalIdInput
        ) {
          return;
        }

        const uploadFile = async (file) => {
          const response = await fetch('/admin/hospitals/upload-url', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ contentType: file.type }),
          });

          if (!response.ok) {
            throw new Error('Could not get upload url.');
          }

          const { url } = await response.json();

          const uploadResponse = await fetch(url, {
            method: 'PUT',
            headers: {
              'Content-Type': file.type,
            },
            body: file,
          });

          if (!uploadResponse.ok) {
            throw new Error('Could not upload cover image.');
          }

          return uploadResponse.url.split('?')[0];
        };

        const showAlert = (message, type) => {
          alertBox.textContent = message;
          alertBox.classList.remove('d-none', 'alert-success', 'alert-danger');
          alertBox.classList.add(type === 'success' ? 'alert-success' : 'alert-danger');
        };

        const buildPayload = () => ({
          name: String(document.getElementById('name').value || '').trim(),
          city: String(document.getElementById('city').value || '').trim() || undefined,
          country: String(document.getElementById('country').value || '').trim() || undefined,
          address: String(document.getElementById('address').value || '').trim() || undefined,
          phone: String(document.getElementById('phone').value || '').trim() || undefined,
          email: String(document.getElementById('email').value || '').trim() || undefined,
          website: String(document.getElementById('website').value || '').trim() || undefined,
          instagramUrl: String(document.getElementById('instagramUrl').value || '').trim() || undefined,
          description: String(document.getElementById('description').value || '').trim() || undefined,
          coverImageUrl: String(coverImageUrlInput.value || '').trim() || undefined,
          rating: Number(document.getElementById('rating').value || 0),
          reviewCount: Number(document.getElementById('reviewCount').value || 0),
          isVerified: document.getElementById('isVerified').checked,
          instagramVerified: document.getElementById('instagramVerified').checked,
          techniques: Array.from(document.getElementById('techniques').selectedOptions).map(
            (option) => option.value,
          ),
        });

        const updateHospital = async (payload) => {
          const response = await fetch(`/admin/hospitals/${hospitalIdInput.value}`, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
            },
            body: JSON.stringify(payload),
          });

          if (!response.ok) {
            const responseText = await response.text();
            let responseBody = null;

            if (responseText) {
              try {
                responseBody = JSON.parse(responseText);
              } catch (error) {
                responseBody = null;
              }
            }

            const errorMessage =
              responseBody?.message ||
              responseBody?.error ||
              response.statusText ||
              'Hospital could not be updated.';

            throw new Error(Array.isArray(errorMessage) ? errorMessage.join(', ') : errorMessage);
          }
        };

        uploadButton.addEventListener('click', async function () {
          const selectedFile = coverImageFileInput.files && coverImageFileInput.files[0];

          if (!selectedFile) {
            showAlert('Please select an image file first.', 'error');
            return;
          }

          uploadButton.disabled = true;
          updateButton.disabled = true;
          alertBox.classList.add('d-none');

          try {
            const uploadedImageUrl = await uploadFile(selectedFile);
            coverImageUrlInput.value = uploadedImageUrl;
            await updateHospital({ coverImageUrl: uploadedImageUrl });
            coverImagePreview.setAttribute('src', uploadedImageUrl);
            coverImagePreview.classList.remove('d-none');
            coverImageFileInput.value = '';
            showAlert('Cover image uploaded and saved successfully.', 'success');
          } catch (error) {
            const message = error instanceof Error ? error.message : 'Unexpected error occurred.';
            showAlert(message, 'error');
          } finally {
            uploadButton.disabled = false;
            updateButton.disabled = false;
          }
        });

        updateButton.addEventListener('click', async function () {
          updateButton.disabled = true;
          alertBox.classList.add('d-none');

          try {
            await updateHospital(buildPayload());

            showAlert('Hospital updated successfully.', 'success');
          } catch (error) {
            const message = error instanceof Error ? error.message : 'Unexpected error occurred.';
            showAlert(message, 'error');
          } finally {
            updateButton.disabled = false;
          }
        });

        deleteButton.addEventListener('click', async function () {
          const confirmed = window.confirm('Are you sure you want to delete this hospital?');
          if (!confirmed) {
            return;
          }

          deleteButton.disabled = true;
          alertBox.classList.add('d-none');

          try {
            const response = await fetch(`/admin/hospitals/${hospitalIdInput.value}`, {
              method: 'DELETE',
              headers: {
                Accept: 'application/json',
              },
            });

            if (!response.ok) {
              throw new Error('Hospital could not be deleted.');
            }

            window.location.href = '/admin/hospitals';
          } catch (error) {
            const message = error instanceof Error ? error.message : 'Unexpected error occurred.';
            showAlert(message, 'error');
            deleteButton.disabled = false;
          }
        });
      });
    </script>
  </body>
</html>
