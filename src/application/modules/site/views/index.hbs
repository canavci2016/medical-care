<!-- HERO -->
<section class='hero'>
  <img
    src='https://mgx-backend-cdn.metadl.com/generate/images/1058559/2026-03-25/06dea3e8-36a3-44d9-b7b8-3394e65e1d35.png'
    alt='Hair transplant clinic'
    class='hero-bg-image'
  />
  <div class='container'>
    <div class='hero-content'>
      <h1>Find the Best
        <span>Hair Transplant</span>
        Hospitals & Doctors</h1>
      <p>Discover top-rated clinics, experienced surgeons, and real patient
        results. Your journey to confidence starts here with verified hospitals
        and proven outcomes.</p>
      <div class='hero-actions'>
        <a href='/hospitals' class='btn btn-primary'>Browse Hospitals</a>
        <a
          href='/results'
          class='btn btn-outline'
          style='border-color: #fff; color: #fff;'
        >View Results</a>
      </div>
      <div class='hero-stats'>
        <div class='hero-stat'>
          <span class='number' data-count='{{hospitalCount}}'>0</span>
          <span class='label'>Partner Hospitals</span>
        </div>
        <div class='hero-stat'>
          <span class='number' data-count='50000'>0</span>
          <span class='label'>Procedures Done</span>
        </div>
      </div>
    </div>
    <div class='hero-image'>
      <img
        src='https://mgx-backend-cdn.metadl.com/generate/images/1058559/2026-03-25/bcdad408-8479-4318-8ce6-df46b8d4435e.png'
        alt='Doctor consultation'
      />
      <div class='floating-card top-right'>
        <div class='icon green'>✓</div>
        <div class='info'>
          <div class='value'>98.5%</div>
          <div class='desc'>Success Rate</div>
        </div>
      </div>
      <div class='floating-card bottom-left'>
        <div class='icon blue'>★</div>
        <div class='info'>
          <div class='value'>4.9/5.0</div>
          <div class='desc'>Patient Rating</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- STATS BAR -->
<section class='stats-bar'>
  <div class='container'>
    <div class='stat-item fade-in'>
      <span class='stat-number' data-count='{{hospitalCount}}'>0</span>
      <span class='stat-label'>Partner Hospitals</span>
    </div>
    <div class='stat-item fade-in'>
      <span class='stat-number' data-count='50000'>0</span>
      <span class='stat-label'>Successful Procedures</span>
    </div>
    <div class='stat-item fade-in'>
      <span class='stat-number' data-count='35'>0</span>
      <span class='stat-label'>Countries Served</span>
    </div>
  </div>
</section>

<!-- FEATURED HOSPITALS -->
<section class='section' id='hospitals'>
  <div class='container'>
    <div class='section-header fade-in'>
      <span class='label'>Our Partners</span>
      <h2>Featured Hospitals</h2>
      <p>Explore world-class hair transplant clinics with proven track records
        and cutting-edge technology.</p>
    </div>
    <div class='grid-3'>
      {{#each hospitals}}
      <!-- Hospital 1 -->
      <a href='/hospitals/{{this.id}}' class='card fade-in'>
        <div class='card-image'>
          <img
            src='{{this.coverImageUrl}}'
            alt='{{this.name}}'
          />
          <div class='overlay'>
            <span class='badge badge-green'>Verified</span>
          </div>
        </div>
        <div class='card-body'>
          <h3>{{this.name}}</h3>
          <div class='location'>
            <svg
              width='14'
              height='14'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2'
            ><path d='M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z' /><circle
                cx='12'
                cy='10'
                r='3'
              /></svg>
            {{this.city}},
          {{this.country}}
          </div>
          <div class='tags'>
            {{#each this.techniques}}
            <span class='badge badge-blue'>{{this}}</span>
            {{/each}}
          </div>
          <div class='meta'>
            <div class='rating'>
              <div class='stars'>{{{stars this.rating}}}</div>
              <span class='score'>{{this.rating}}</span>
            </div>
            <span class='procedures'>{{this.procedures}}+ procedures</span>
          </div>
        </div>
      </a>
      {{/each}}
    </div>
    <div style='text-align: center; margin-top: 40px;'>
      <a href='/hospitals' class='btn btn-outline'>View All Hospitals →</a>
    </div>
  </div>
</section>

<!-- BEFORE/AFTER RESULTS PREVIEW -->
<section class='section'>
  <div class='container'>
    <div class='section-header fade-in'>
      <span class='label'>Real Transformations</span>
      <h2>Patient Results</h2>
      <p>See real before and after photos from verified patients across our
        partner hospitals.</p>
    </div>
    <div class='grid-3'>
      {{#each results}}
      <div class='ba-card fade-in'>
        <div class='ba-images'>
          <div class='ba-img'>
            <img
              src='{{this.image}}'
              alt='Before'
            />
            <span class='ba-label before'>Before</span>
          </div>
          <div class='ba-img'>
            <img
              src='{{this.image}}'
              alt='After'
            />
            <span class='ba-label after'>After</span>
          </div>
          <div class='divider'></div>
        </div>
        <div class='ba-info'>
          <h4>{{this.technique}} Hair Transplant — {{this.graftCount}} Grafts</h4>
          <div class='ba-meta'>
            <span>👨‍⚕️ Dr. {{this.doctor}}</span>
            <span>🏥 {{this.hospital.name}}</span>
            <span>📅 {{this.postOpDuration}} months post-op</span>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
    <div style='text-align: center; margin-top: 40px;'>
      <a href='/results' class='btn btn-outline'>View All Results →</a>
    </div>
  </div>
</section>

<!-- TESTIMONIALS -->
<section class='section' style='background: #fff;'>
  <div class='container'>
    <div class='section-header fade-in'>
      <span class='label'>Patient Stories</span>
      <h2>What Our Patients Say</h2>
      <p>Real testimonials from patients who transformed their lives through our
        partner hospitals.</p>
    </div>
    <div class='grid-3'>
      {{#each reviews}}
      <div class='testimonial-card fade-in'>
        <span class='quote-icon'>"</span>
        <div class='stars'>{{{stars this.rating}}}</div>
        <p class='testimonial-text'>{{slice this.comment 0 150}}</p>
        <div class='testimonial-author'>
          <div class='author-avatar'>J</div>
          <div>
            <div class='author-name'>{{this.authorName}}</div>
            <div class='author-detail'>{{this.detail}}</div>
          </div>
        </div>
      </div>
      {{/each}}
    
    </div>
  </div>
</section>

<!-- CTA -->
<section class='cta-section'>
  <div class='container'>
    <h2>Ready to Start Your Hair Restoration Journey?</h2>
    <p>Connect with top-rated hospitals and experienced surgeons. Get a free
      consultation and personalized treatment plan today.</p>
    <div class='cta-actions'>
      <a href='/contact' class='btn btn-primary'>Get Free Consultation</a>
      <a
        href='/hospitals'
        class='btn btn-outline'
        style='border-color: #fff; color: #fff;'
      >Browse Hospitals</a>
    </div>
  </div>
</section>