    <div class='container'>
      <section>
        <form action="/results" method="GET">
          <h1>Find Real Hair Transplant Results</h1>

          <div class='search-box'>
            <input name="name" placeholder='Search by hospital, city, technique...' />
            <select name="technique">
              {{#each techniques}}
                <option value="{{value}}">{{label}}</option>
              {{/each}}
            </select>

            <select name="duration">
              {{#each availableMonths}}
                <option value="{{value}}">{{label}}</option>
              {{/each}}
            </select>
            <button type="submit" class='btn'>Search</button>
          </div>
        </form>    <h2>Latest Results</h2>
        <div class='grid'>
          {{#each results}}

          <div class='card'>
            <img
              src='{{#if image}}{{image}}{{else}}https://via.placeholder.com/400x300?text=No+Image{{/if}}'
              class='img'
              style="width: 100%;"
              alt=''
            />
            <div class='card-body'>
              <strong>{{hospital.name}}</strong>
              {{#if verified}}
              <span class='badge'>Verified</span>
              {{/if}}
              <div class='muted'>{{operationDateRelative}} · {{graftCount}} grafts</div>
            </div>
          </div>
          {{/each}}
        </div>
      </section>
    </div>