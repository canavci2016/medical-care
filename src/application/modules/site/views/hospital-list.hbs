<div class="container">

  <!-- Sidebar -->
  <div class="sidebar">
    <h3>Filters</h3>

    <form method="GET">
      <label>City</label>
      <select name="city">
        <option value="">All</option>
        {{#each filters.cities}}
        <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>

      <label>Rating</label>
      <select name="rating">
        <option value="">All</option>
        {{#each filters.stars}}
        <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>

      <label>Sort By</label>
      <select name="sorting">
        <option value="">Default</option>
        {{#each filters.sorts}}
        <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>

      <button type="submit">Apply Filters</button>
    </form>
  </div>

  <!-- Content -->
  <div class="content">

    <div class="top-bar">
      <div>Showing {{pagination.length}} of {{pagination.total}} hospitals</div>
      <div>Sorted by: Rating High → Low</div>
    </div>

    <!-- Hospital 1 -->
    {{#each hospitals}}
    <div class="hospital-card">
      <img src="{{coverImageUrl}}" alt="{{name}} hospital cover image in {{city}}">
      <div class="card-content">
        <h4>{{name}}</h4>
        <p><strong>City:</strong> {{city}}</p>
        <p><strong>Rating:</strong> {{rating}}</p>
        <button class="view-btn" onclick="window.location.href='/hospitals/{{this.id}}'">View Profile</button>
      </div>
    </div>
    {{/each}}

    <!-- Pagination -->

    {{> pagination pagination=pagination }}

  </div>

</div>