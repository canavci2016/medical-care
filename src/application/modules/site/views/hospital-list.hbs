<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Hospitals</title>

    <style>
      body {
        font-family: system-ui, sans-serif;
        background: #f9fafb;
        margin: 0;
      }

      header {
        background: white;
        border-bottom: 1px solid #e5e7eb;
        padding: 16px 24px;
      }

      .container {
        max-width: 1200px;
        margin: 32px auto;
        padding: 0 16px;
      }

      .controls {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
        flex-wrap: wrap;
      }

      .controls select {
        padding: 8px 12px;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
      }

      .hospital-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 24px;
      }

      .hospital-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        overflow: hidden;
        display: none;
        flex-direction: column;
      }

      .hospital-card img {
        width: 100%;
        height: 180px;
        object-fit: cover;
      }

      .content {
        padding: 16px;
      }

      .hospital-meta {
        display: flex;
        justify-content: space-between;
        font-size: 14px;
      }

      .footer {
        border-top: 1px solid #e5e7eb;
        padding: 12px;
        text-align: right;
      }

      .footer button {
        background: #2563eb;
        color: white;
        border: none;
        padding: 8px 14px;
        border-radius: 6px;
        cursor: pointer;
      }

      .load-more {
        margin: 32px 0;
        text-align: center;
      }

      .load-more button {
        padding: 10px 20px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        background: white;
        cursor: pointer;
      }
    </style>
  </head>

  <body>

    <header>
      <h1>Hospitals</h1>
    </header>

    <div class='container'>

      <!-- CONTROLS -->
      <div class='controls'>
        <select id='cityFilter'>
          <option value=''>All Cities</option>
          <option value='Istanbul'>Istanbul</option>
          <option value='Ankara'>Ankara</option>
          <option value='Izmir'>Izmir</option>
        </select>

        <select id='ratingFilter'>
          <option value=''>Min Rating</option>
          <option value='4.5'>4.5+</option>
          <option value='4.7'>4.7+</option>
          <option value='4.9'>4.9+</option>
        </select>

        <select id='sortSelect'>
          <option value=''>Sort</option>
          <option value='rating'>Highest Rating</option>
          <option value='results'>Most Results</option>
        </select>
      </div>

      <!-- GRID -->
      <div class='hospital-grid' id='grid'>

        {{#each hospitals}}
          <div
            class='hospital-card'
            data-city='Istanbul'
            data-rating='4.8'
            data-results='120'
          >
            <img src='{{this.coverImageUrl}}' />
            <div class='content'>
              <h3>{{this.name}}</h3>
              <p>{{this.city}}, {{this.country}}</p>
              <div class='hospital-meta'>
                <span>⭐ {{this.rating}}</span>
                <span>100 Results</span>
              </div>
            </div>
            <div class='footer'>
              <button onclick="window.location.href='/hospitals/{{this.id}}'">View Profile</button>
            </div>
          </div>
        {{/each}}

      </div>

      <div class='load-more'>
        <button id='loadMore'>Load more</button>
      </div>

    </div>

    <script>
      const cards = Array.from(document.querySelectorAll('.hospital-card'));
      const grid = document.getElementById('grid'); const loadMoreBtn =
      document.getElementById('loadMore'); let visibleCount = 6; let
      filteredCards = [...cards]; function render() { grid.innerHTML = '';
      filteredCards.forEach((card, index) => { if (index < visibleCount) {
      card.style.display = 'flex'; grid.appendChild(card); } }); } function
      applyFiltersAndSort() { const city = cityFilter.value; const minRating =
      parseFloat(ratingFilter.value || 0); filteredCards = cards.filter(card =>
      { return (!city || card.dataset.city === city) &&
      parseFloat(card.dataset.rating) >= minRating; }); if (sortSelect.value ===
      'rating') { filteredCards.sort((a, b) => b.dataset.rating -
      a.dataset.rating); } if (sortSelect.value === 'results') {
      filteredCards.sort((a, b) => b.dataset.results - a.dataset.results); }
      visibleCount = 6; render(); } loadMoreBtn.addEventListener('click', () =>
      { visibleCount += 6; render(); }); cityFilter.addEventListener('change',
      applyFiltersAndSort); ratingFilter.addEventListener('change',
      applyFiltersAndSort); sortSelect.addEventListener('change',
      applyFiltersAndSort); applyFiltersAndSort();
    </script>

  </body>
</html>